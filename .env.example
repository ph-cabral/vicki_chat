# ── Base de datos (elegí una de las dos formas) ───────────────────────────────
# Opción A: URL completa
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db
# Opción B: variables separadas (docker-compose las pasa así)
# POSTGRES_HOST=n8n_sql
# POSTGRES_PORT=5432
# POSTGRES_DB=n8n
# POSTGRES_USER=n8n
# POSTGRES_PASSWORD=tu_contraseña

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_API_MODEL=gpt-4.1-mini
ANTHROPIC_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
MODEL_NAME=gpt-4.1-mini

# ── Relojes / cámaras Hikvision ──────────────────────────────────────────────
HIK_USER=admin
HIK_PASS=tu_contraseña_hikvision
HIK_DEVICES=[{"host":"10.10.0.10","name":"fabrica"}]
HIK_IPS=10.10.0.10,10.10.0.11
# Para cámaras si difieren del usuario Hikvision principal (opcional):
# CAMERA_USER=admin
# CAMERA_PASS=otra_contraseña

# ── Qdrant (vector DB para CVs) ───────────────────────────────────────────────
QDRANT_URL=http://n8n_qdrant:6333
QDRANT_COLLECTION=cvs
# QDRANT_API_KEY=   # solo si Qdrant tiene auth

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS=http://10.10.0.159:3001,http://localhost:3001

# ── Ubicaciones de cámaras (JSON, opcional) ──────────────────────────────────
# LOCATIONS_JSON=[{"name":"entrada","ip":"10.10.0.10"},{"name":"deposito","ip":"10.10.0.11"}]

# ── Zona horaria ─────────────────────────────────────────────────────────────
TZ=America/Argentina/Buenos_Aires
